              },
              {
                "id": 2,
                "icon": "front_hand",
                "title": "Rule 2 ✋",
                "text": "Always use a capital for the word I:",
                "examples": ["I am eight years old.", "Tom and I are good friends."]
              },
              {
                "id": 3,
                "icon": "person",
                "title": "Rule 3 👤",
                "text": "Use a capital for NAMES of people:",
                "examples": ["Alice, Tom, James, Kim, Snow White"]
              },
              {
                "id": 4,
                "icon": "public",
                "title": "Rule 4 🌍",
                "text": "Use a capital for NAMES of places:",
                "examples": ["National Museum, Bronx Zoo, London, Sacramento"]
              },
              {
                "id": 5,
                "icon": "calendar_month",
                "title": "Rule 5 📅",
                "text": "Use a capital for festivals, holidays, days, months:",
                "examples": ["New Year's Day, Christmas, Monday, January"]
