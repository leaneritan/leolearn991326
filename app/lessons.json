              { "label": "❌ Incorrect Grammar", "id": "incorrect" }
            ],
            "items": [
              { "text": "The teacher is kind.", "box": "correct" },
              { "text": "Kind teacher the is.", "box": "incorrect" },
              { "text": "I love football.", "box": "correct" },
              { "text": "Football love I the.", "box": "incorrect" },
              { "text": "Birds can fly.", "box": "correct" },
              { "text": "Fly can birds the.", "box": "incorrect" }
            ]
