  "chapters": [
    {
      "id": 1,
      "title": "What is Grammar?",
      "lessons": [
        {
          "id": "1.1",
          "title": "What is Grammar?",
          "badge": "Lesson 1 of 1",
          "icon": "school",
          "content": "Grammar is the set of rules that helps us speak and write correctly. Every language has grammar rules. We use grammar every day without thinking about it!",
          "keyTakeaways": [
            "Grammar = rules for speaking and writing",
            "Good grammar helps people understand us",
            "We use grammar in every sentence we say"
          ],
          "examples": [
            { "title": "Correct", "subtitle": "\"The cat is sleeping.\"", "icon": "check_circle" },
            { "title": "Incorrect", "subtitle": "\"Cat the sleeping is.\"", "icon": "cancel" }
          ],
          "quiz": [
            {
              "question": "What is grammar?",
              "type": "multiple",
              "options": ["Rules for speaking and writing", "A type of book", "A school subject", "A foreign language"],
              "answer": 0
            },
            {
              "question": "Every language has grammar rules.",
              "type": "tf",
              "answer": true
            },
            {
              "question": "Grammar helps us speak and _____ correctly.",
              "type": "blank",
              "answer": "write"
            },
            {
              "question": "We only use grammar when we write.",
              "type": "tf",
              "answer": false
            },
            {
              "question": "Which sentence is correct?",
              "type": "multiple",
              "options": ["\"The dog is running.\"", "\"Dog the running is.\""],
              "answer": 0
            }
          ]
        }
      ]
    },
    {
      "id": 2,
      "title": "The Capital Letter",
      "lessons": [
        {
          "id": "2.1",
          "title": "The Capital Letter",
          "badge": "Lesson 1 of 1",
          "icon": "format_size",
          "content": "We use capital letters at the beginning of every sentence, for names of people and places, for days of the week and months of the year, and for the word \"I\".",
          "keyTakeaways": [
            "Always start a sentence with a capital letter",
            "Names of people use capital letters",
            "Days and months use capital letters",
            "The word \"I\" is always capital"
          ],
          "examples": [
            { "title": "Names", "subtitle": "\"My name is Leo.\"", "icon": "person" },
            { "title": "Days", "subtitle": "\"Today is Monday.\"", "icon": "calendar_today" },
            { "title": "Places", "subtitle": "\"I live in Japan.\"", "icon": "location_city" }
          ],
          "quiz": [
            {
              "question": "Every sentence starts with a capital letter.",
              "type": "tf",
              "answer": true
            },
            {
              "question": "The word '___' is always written with a capital letter.",
              "type": "blank",
              "answer": "I"
            },
            {
              "question": "Which is correct?",
              "type": "multiple",
              "options": ["\"my name is leo.\"", "\"My name is Leo.\""],
              "answer": 1
            },
            {
              "question": "Days of the week start with a small letter.",
              "type": "tf",
              "answer": false
            },
            {
              "question": "Today is _____day. (the day after Sunday)",
              "type": "blank",
              "answer": "Mon"
            }
          ]
        }
      ]
    },
