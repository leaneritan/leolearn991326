              { "text": "The dog is barking.", "label": "Correct grammar!", "status": "correct" },
              { "text": "Dog the barking is.", "label": "Incorrect grammar!", "status": "incorrect" }
            ],
            "funFact": "You use grammar every time you speak — even without thinking about it! 🤯"
          },
          "practice": {
            "title": "Is it correct or incorrect grammar?",
            "type": "pick_correct",
            "items": [
              { "options": ["The cat is sleeping.", "Cat sleeping the is."], "answer": 0 },
              { "options": ["Running fast boy.", "The boy is running fast."], "answer": 1 },
              { "options": ["She likes football.", "Football she likes is."], "answer": 0 },
              { "options": ["I have a book.", "Book a have I."], "answer": 0 },
              { "options": ["Happy is Leo.", "Leo is happy."], "answer": 1 }
            ]
          },
          "game": {
            "title": "Sort the sentences! 🎮",
